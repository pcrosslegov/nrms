# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://nrms:nrms_dev@localhost:5432/nrms?schema=public"

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production"
JWT_EXPIRY="24h"

# ─── Storage ─────────────────────────────────────────────────
# Local filesystem path (default: ./uploads)
STORAGE_PATH="./uploads"

# ─── SMTP (optional — email disabled when not set) ───────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=nrms@gov.nb.ca

# ─── Flickr (optional) ──────────────────────────────────────
# FLICKR_API_KEY=
# FLICKR_API_SECRET=

# ─── Keycloak (future) ──────────────────────────────────────
# KEYCLOAK_URL=https://auth.example.com
# KEYCLOAK_REALM=nrms
# KEYCLOAK_CLIENT_ID=nrms-app

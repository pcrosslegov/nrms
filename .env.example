# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://nrms:nrms_dev@localhost:5432/nrms?schema=public"

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production"
JWT_EXPIRY="24h"

# ─── Storage ─────────────────────────────────────────────────
# Local filesystem path (default: ./uploads)
STORAGE_PATH="./uploads"

# ─── SMTP (optional — email disabled when not set) ───────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=nrms@gov.nb.ca

# ─── Flickr (optional) ──────────────────────────────────────
# FLICKR_API_KEY=
# FLICKR_API_SECRET=

# ─── Azure AD (optional — enables "Sign in with Microsoft") ──
# When set, login page shows Microsoft SSO alongside local auth.
# Users are auto-provisioned on first Azure AD login.
# AZURE_AD_TENANT_ID=your-tenant-guid
# AZURE_AD_CLIENT_ID=your-app-client-id
# AZURE_AD_REDIRECT_URI=http://localhost:5173
